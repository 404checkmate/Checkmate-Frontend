# ==============================================
# Travel Checklist - 환경변수 템플릿
# ==============================================
# 이 파일은 git에 포함됩니다. 값은 절대 입력하지 마세요.
# 실제 값은 .env (또는 .env.local) 파일에 입력하세요.
# 새로운 환경변수가 추가되면 이 파일에도 키를 추가해주세요.
# ==============================================

# ----------------------------------------------
# 앱 기본 설정
# ----------------------------------------------
VITE_APP_NAME=
VITE_APP_ENV=                    # development | staging | production

# ----------------------------------------------
# 백엔드 API
# ----------------------------------------------
# 로컬 개발 권장값: "/api"  (Vite dev server 의 proxy 를 태움 → CORS 무관)
# 운영/외부 API: 절대 URL 을 그대로 쓴다 (예: https://api.your-domain.com/api)
# 절대 URL 로 두면 백엔드의 CORS_ORIGIN 설정이 반드시 맞아야 한다.
VITE_API_BASE_URL=/api

# Vite 프록시가 포워딩할 백엔드 주소. 기본값: http://localhost:8080
# VITE_DEV_PROXY_TARGET=http://localhost:8080

# ----------------------------------------------
# Supabase (Google/Kakao 소셜 로그인)
# ----------------------------------------------
# Google / Kakao 소셜 로그인은 Supabase Auth 가 처리.
# ⚠️ 반드시 VITE_ prefix 유지. SUPABASE_URL 은 루트 URL (`/rest/v1/` 금지).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ----------------------------------------------
# 분석 도구 (사용자 행동 이벤트 수집)
# 04_meta_okr.md 참고 - 이벤트 수집 구조
# ----------------------------------------------
VITE_ANALYTICS_KEY=              # Mixpanel / Amplitude 등 추후 결정

# ----------------------------------------------
# Notion (빌드 타임 큐레이션 콘텐츠 fetch — prebuild 스크립트용)
# ⚠️ VITE_ prefix 없음: 브라우저에 노출되지 않음
# 로컬과 Vercel 환경변수 모두 설정 필요
# ----------------------------------------------
NOTION_API_KEY=
NOTION_ARTICLES_DB_ID=
NOTION_SECTIONS_DB_ID=
NOTION_APPS_DB_ID=
NOTION_CHECKLIST_DB_ID=

# ----------------------------------------------
# 기타 외부 서비스 (추후 추가)
# ----------------------------------------------
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_SENTRY_DSN=
